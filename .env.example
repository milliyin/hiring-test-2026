# ─── Firebase (emulator — these values are fine as-is for local dev) ───────────
EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSy-REPLACE-ME
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=clinic-test-local.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=clinic-test-local
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=clinic-test-local.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
EXPO_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000

# ─── Emulator ───────────────────────────────────────────────────────────────────
EXPO_PUBLIC_USE_EMULATOR=true
EXPO_PUBLIC_EMULATOR_HOST=127.0.0.1

# ─── Stripe (client-side publishable key only — secret key goes in functions/.env)
# Get from https://dashboard.stripe.com/test/apikeys
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME
