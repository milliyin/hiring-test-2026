rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions

    function isAuthenticated() {
      return request.auth != null;
    }

    // Safe user data fetch — returns null if the doc doesn't exist yet.
    // Guards against the race condition where Firebase Auth fires before the
    // users/{uid} doc has been committed (e.g. immediately after signup).
    function getUserData() {
      let ref = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(ref) ? get(ref).data : null;
    }

    function getUserRole() {
      let data = getUserData();
      return data != null ? data.role : null;
    }

    function isOwner() {
      return isAuthenticated() && getUserRole() == 'owner';
    }

    function isStaff() {
      return isAuthenticated() && (getUserRole() == 'staff' || getUserRole() == 'owner');
    }

    function belongsToClinic(clinicId) {
      let data = isAuthenticated() ? getUserData() : null;
      return data != null && data.clinicId == clinicId;
    }

    // Returns the clinicId for the current user — null if no user doc yet.
    function getUserClinicId() {
      let data = getUserData();
      return data != null ? data.clinicId : null;
    }

    // Safe subscription fetch — returns null if the doc doesn't exist yet.
    function getSubscription(clinicId) {
      let ref = /databases/$(database)/documents/subscriptions/$(clinicId);
      return exists(ref) ? get(ref).data : null;
    }

    function getClinicPlan(clinicId) {
      let sub = getSubscription(clinicId);
      return sub != null ? sub.plan : 'free';
    }

    // True when the clinic's subscription is in a state where existing features
    // remain accessible (active OR within the 7-day grace period after payment failure).
    function clinicIsActive(clinicId) {
      let sub = getSubscription(clinicId);
      return sub != null && (sub.status == 'active' || sub.status == 'grace_period');
    }

    // True ONLY when the subscription is fully active — not in grace period.
    // Used to block new staff additions during payment failure (Scenario 4).
    function clinicIsFullyActive(clinicId) {
      let sub = getSubscription(clinicId);
      return sub != null && sub.status == 'active';
    }

    // True when the user has an active seat in the clinic.
    // Checked on appointment access so that a removed staff member loses access
    // immediately when their seat is deactivated — even if their ID token hasn't
    // expired yet (closes the 1-hour window left by revokeRefreshTokens alone).
    function isSeatActive(clinicId, userId) {
      let ref = /databases/$(database)/documents/seats/$(clinicId)/members/$(userId);
      return exists(ref) && get(ref).data.active == true;
    }

    // Clinics collection
    match /clinics/{clinicId} {
      allow read: if isAuthenticated() && belongsToClinic(clinicId);
      allow create: if isAuthenticated(); // Owner creates clinic on signup
      allow update: if isOwner() && belongsToClinic(clinicId);
      allow delete: if false; // Clinics are never deleted via client
    }

    // Users collection
    match /users/{userId} {
      // Users can read their own profile; owners can read their clinic members
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isOwner()
      );
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        isOwner() // Owner can update roles
      );
      allow delete: if false;
    }

    // Subscriptions
    match /subscriptions/{clinicId} {
      allow read: if isAuthenticated() && belongsToClinic(clinicId);
      // Writes come exclusively from Cloud Functions via the Admin SDK.
      // The Admin SDK bypasses Firestore rules entirely — allow write: if false
      // blocks all client writes while leaving Admin SDK writes unaffected.
      allow write: if false;
    }

    // Add-ons
    match /addons/{clinicId}/items/{addonId} {
      allow read: if isAuthenticated() && belongsToClinic(clinicId);
      allow write: if false; // Admin SDK only (Cloud Functions)
    }

    // Discounts — readable by owners to display in billing UI
    match /discounts/{discountId} {
      allow read: if isOwner();
      allow write: if false; // Admin SDK only (Cloud Functions)
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (
        // Staff/owners: must have an active seat — closes the window between
        // seat deactivation and token expiry (Scenario 6 enforcement at rule level)
        (isStaff() && isSeatActive(getUserClinicId(), request.auth.uid)) ||
        // Patients see only their own appointments
        resource.data.patientId == request.auth.uid
      );

      // Only staff with an active seat can create or update appointments
      allow create: if isStaff() && isSeatActive(getUserClinicId(), request.auth.uid);
      allow update: if isStaff() && isSeatActive(getUserClinicId(), request.auth.uid);
      allow delete: if isOwner() && isSeatActive(getUserClinicId(), request.auth.uid);
    }

    // Seats
    match /seats/{clinicId}/members/{userId} {
      allow read: if isAuthenticated() && belongsToClinic(clinicId);

      // Writes are owner-only. For new active seats, enforce plan limit and active-subscription check.
      allow write: if isOwner() && belongsToClinic(clinicId) && (
        // Allow deactivating a seat (active: false) or deleting — no limit check needed
        (request.resource == null || request.resource.data.active == false) ||
        // Allow activating / creating a seat only if subscription is FULLY active
        // (grace_period intentionally excluded — no new staff during payment failure)
        // and seat capacity exists.
        (
          clinicIsFullyActive(clinicId) &&
          get(/databases/$(database)/documents/clinics/$(clinicId)).data.seats.used <
          get(/databases/$(database)/documents/clinics/$(clinicId)).data.seats.max
        )
      );
    }
  }
}
