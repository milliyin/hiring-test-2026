# ─── Stripe ──────────────────────────────────────────────────────────────────────
# Secret key — from https://dashboard.stripe.com/test/apikeys (sk_test_...)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Webhook secret — printed by `stripe listen` when you start the CLI listener (whsec_...)
# Run: stripe listen --forward-to http://127.0.0.1:5001/clinic-test-local/us-central1/stripeWebhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ─── App URL (for Stripe Checkout redirect after payment) ────────────────────────
# Local dev: http://localhost:8081
# Production: your deployed app URL
APP_URL=http://localhost:8081

# ─── Stripe Price IDs ────────────────────────────────────────────────────────────
# Create products at https://dashboard.stripe.com/test/products
# Each product needs a recurring monthly price in CHF.
# Copy the price_... ID for each here.
#
# Suggested prices (CHF/month):
#   Pro: 49 | Premium: 99 | VIP: 199
#   Extra Storage: 9 | Extra Seats: 19 | Advanced Analytics: 29
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_PREMIUM=price_REPLACE_ME
STRIPE_PRICE_VIP=price_REPLACE_ME
STRIPE_PRICE_EXTRA_STORAGE=price_REPLACE_ME
STRIPE_PRICE_EXTRA_SEATS=price_REPLACE_ME
STRIPE_PRICE_ADVANCED_ANALYTICS=price_REPLACE_ME
